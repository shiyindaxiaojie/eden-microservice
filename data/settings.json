{
  "mode": "ap",
  "environment": "standalone",
  "log_level": "WARN",
  "log_retention_days": 30,
  "event_types": [
    "service_register",
    "service_online",
    "service_offline",
    "registry_node_sync",
    "service_heartbeat",
    "service_remove"
  ],
  "heartbeat_max_failures": 3,
  "instance_removal_delay_seconds": 600,
  "api_key_auth_enabled": false,
  "notify_alert_node_id": "node-1",
  "event_storage_mode": "persistent",
  "event_retention_days": 30,
  "metrics_storage_mode": "persistent",
  "metrics_retention_days": 14
}