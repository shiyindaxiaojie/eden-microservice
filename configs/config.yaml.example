############################################################
# Eden Registry 核心启动配置
############################################################

# 节点基本标识
node_id: "node-1"

# 运行模式：ap (高性能/弱一致) 或 cp (强一致，基于Raft)
# 可在控制台动态切换
mode: "ap"

# 数据中心名称，用于多数据中心隔离
datacenter: "dc1"

# 数据存储目录（各节点必须隔离）
data_dir: "./data"

############################################################
# 网络监听配置（支持端口动态分配）
############################################################

# HTTP 管理API 和 控制台监听地址 (必须明确指定)
http_addr: ":8500"

# gRPC 监听地址 (用于数据同步)
#   - 不填 或 填写 ":0" 则表示随机端口
#   - 其他节点可通过 http_addr 获取此地址
grpc_addr: ":0"

# QUIC 监听地址 (基于UDP的gRPC传输)
#   - 不填 或 填写 ":0" 则表示随机端口
quic_addr: ""

# Raft 内部通信地址 (CP 模式必备)
#   - 注意：Raft 要求必须有明确的 IP (如 127.0.0.1 或 局域网IP)
#   - 建议填写 "127.0.0.1:7000" 或 留空以自动分配 "127.0.0.1:随机端口"
#   - 错误写法: ":7000" 或 "0.0.0.0:7000" (会报错 not advertisable)
raft_addr: ""

############################################################
# 集群启动控制 (仅在 CP 模式下 node-1 使用)
############################################################

# 是否作为首个节点启动 Raft 集群
bootstrap: false

# 加入已有集群的 HTTP 地址（例如 "http://127.0.0.1:8500"）
join: ""

# AP 模式下的种子节点列表（HTTP 地址）
seeds: []

############################################################
# 认证配置
############################################################
auth:
  jwt:
    enabled: true
    secret: "eden-jwt-console-secret-key"
  
  # API Key 相关配置已移至 Web 控制台管理
  # 用户管理也建议在控制台进行，系统会自动持久化到 data/users.json

############################################################
# 日志配置
############################################################
log:
  level: INFO # DEBUG, INFO, WARN, ERROR, FATAL
  format: text # text, json
  pattern: "%d [%p] [%T] %m%n"
  policies:
    cron_triggering_policy:
      schedule: 0 0 4 * * ?
    size_based_triggering_policy:
      size: 20MB
  rollover:
    max_file: 10
    retention: 30d
  appenders:
    - name: Console # Standard output
      type: Console
      pattern: "%d [%p] [%T] %m%n"
    - name: AccessLog # API Request records
      type: RollingFile
      level: INFO
      file_name: "logs/access.log"
      file_pattern: access-%i.log.gz
      async: true
      filter:
        type: marker
        marker: API
        on_match: ACCEPT
        on_mismatch: DENY
      rollover:
        max_file: 5
        retention: 7d
    - name: InfoLog # General business logs
      type: RollingFile
      level: INFO
      file_name: "logs/info.log"
      file_pattern: info-%i.log.gz
      async: true
      rollover:
        max_file: 5
        retention: 7d
    - name: ErrorLog # Error logs with rate limiting
      type: RollingFile
      level: ERROR
      file_name: "logs/error.log"
      file_pattern: error-%i.log.gz
      async: true
      filter: # Burst filter to prevent log flooding
        type: burst
        level: ERROR
        rate: 10 # 10 entries per second
        max_burst: 100 # Allow burst up to 100 entries
        on_match: ACCEPT
        on_mismatch: DENY
      rollover:
        max_file: 10
        retention: 30d
